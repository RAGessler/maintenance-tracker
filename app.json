{
  "expo": {
    "name": "Maintenance Tracker",
    "slug": "maintenance-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "maintenance-tracker",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "com.ragessler.maintenancetracker",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Maintenance Tracker uses your location to confirm a drive and measure trip mileage.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Maintenance Tracker records trip mileage after a CarPlay or car-stereo automation starts a trip.",
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
      "package": "com.ragessler.maintenancetracker",
      "blockedPermissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-sqlite",
      "expo-sharing",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Maintenance Tracker uses your location to confirm a drive and measure trip mileage.",
          "locationAlwaysAndWhenInUsePermission": "Maintenance Tracker records trip mileage after a CarPlay or car-stereo automation starts a trip.",
          "isIosBackgroundLocationEnabled": true
        }
      ],
      "./plugins/with-ios-trip-trigger"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
